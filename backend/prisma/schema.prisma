generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Expense {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  description String
  amountVES   Float
  amountUSD   Float
  exchangeRate Float
}

model ExchangeRate {
  id    Int      @id @default(autoincrement())
  date  DateTime @unique @default(now())
  rate  Float
}
